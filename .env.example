# ═══════════════════════════════════════════════════════════════════════
# Environment selection
#
# Three environments; each uses a different compose overlay stack:
#   • Local dev   → docker-compose.yml:docker-compose.dev.yml  (spins up local postgres + adminer, builds images from source)
#   • Staging VPS → docker-compose.yml:docker-compose.prod.yml (pulls bharat1508/gurukul-*:staging from Docker Hub)
#   • Prod VPS    → docker-compose.yml:docker-compose.prod.yml (pulls bharat1508/gurukul-*:prod    from Docker Hub)
#
# Copy the block matching your environment below and fill in real values.
# ═══════════════════════════════════════════════════════════════════════

# ─── LOCAL DEV DEFAULTS ────────────────────────────────────────────────
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# PostgreSQL — only used by docker-compose.dev.yml (the local postgres service).
# On VPS, these aren't read; the shared postgres in the postgresql-k42d project owns its own creds.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=gurukul_dev

# DATABASE_URL host depends on which compose overlay is active:
#   local:   host=postgres    (service in docker-compose.dev.yml)
#   VPS:     host=postgresql  (service in the external postgresql-k42d compose project)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public"

# Redis — backs the BullMQ queue used for background jobs (e.g. student CSV import).
# Use the docker service name inside compose; use localhost when running the API on the host.
REDIS_HOST=redis
REDIS_PORT=6379

# Access + refresh token secrets. Generate with: openssl rand -hex 64
AT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
RT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET

# Multi-tenancy domain config. APP_DOMAIN is the apex used to derive tenant subdomains from Host header.
APP_DOMAIN=lvh.me
COOKIE_DOMAIN=.lvh.me

# Frontend api URL routing. Empty (default) → `host:PORT` (dev with local api on port 8000).
# Set to `/api` when web is served behind a reverse proxy that forwards /api/* to the api
# service (staging/prod behind Caddy). Because Next.js inlines NEXT_PUBLIC_* at BUILD time,
# staging/prod get this value via `--build-arg` in .github/workflows/build-and-push.yml, not
# from this file.
# NEXT_PUBLIC_API_BASE_PATH=

# Email / password reset
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
FRONTEND_RESET_PASSWORD_URL=

# ─── STAGING VPS (/root/projects/gurukul/staging/.env) ─────────────────
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
#
# # Docker Hub image pins. Deploy workflow pushes both floating (:staging)
# # and immutable (:sha-<7>) tags. Pin to a sha for rollback.
# API_IMAGE=bharat1508/gurukul-api:staging
# WEB_IMAGE=bharat1508/gurukul-web:staging
#
# # Ports bound to 127.0.0.1 on the VPS. Caddy reverse-proxies vhosts to these.
# API_HOST_PORT=8001
# WEB_HOST_PORT=3001
#
# # Shared postgres. Host is `postgresql` (Compose service name in postgresql-k42d stack).
# DATABASE_URL="postgresql://gurukul_staging:<staging_pw>@postgresql:5432/gurukul_staging?schema=public"
#
# # DuckDNS domain for staging. Configure Caddy vhost to gurukul-staging.duckdns.org.
# APP_DOMAIN=gurukul-staging.duckdns.org
# COOKIE_DOMAIN=.gurukul-staging.duckdns.org
#
# # Generate each with: openssl rand -hex 64
# AT_SECRET=<64-hex>
# RT_SECRET=<64-hex>
#
# # SMTP + reset URL (fill in when email is wired)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
# FRONTEND_RESET_PASSWORD_URL=https://gurukul-staging.duckdns.org/reset-password

# ─── PROD VPS (/root/projects/gurukul/prod/.env) ───────────────────────
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
#
# API_IMAGE=bharat1508/gurukul-api:prod
# WEB_IMAGE=bharat1508/gurukul-web:prod
#
# API_HOST_PORT=8000
# WEB_HOST_PORT=3000
#
# DATABASE_URL="postgresql://gurukul_prod:<prod_pw>@postgresql:5432/gurukul_prod?schema=public"
#
# APP_DOMAIN=gurukul.duckdns.org
# COOKIE_DOMAIN=.gurukul.duckdns.org
#
# AT_SECRET=<64-hex>
# RT_SECRET=<64-hex>
#
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
# FRONTEND_RESET_PASSWORD_URL=https://gurukul.duckdns.org/reset-password
