# Docker Compose Configuration
# For development: docker-compose.yml:docker-compose.dev.yml
# For production:  docker-compose.yml:docker-compose.prod.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=gurukul_dev

# Prisma (constructed from above values, host is the docker service name)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public"

# Access token and refresh token secrets.
# Generate with: openssl rand -hex 64
# Required at startup; the app will fail to boot if missing.
AT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
RT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET

# Multi-tenancy domain config
# APP_DOMAIN is the apex used to derive tenant subdomains from the Host header.
#   dev:     localhost
#   staging: staging.gurukul.io
#   prod:    gurukul.io
APP_DOMAIN=lvh.me

# COOKIE_DOMAIN controls the refreshToken cookie scope.
# Leave empty for host-only cookies (recommended for local dev).
# In prod, set to ".gurukul.io" to share the session across tenant subdomains.

# Email / password reset
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=39ea19db261ccc
SMTP_PASSWORD=82c33a4482df98
EMAIL_FROM=no-reply@gurukul.io
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password

COOKIE_DOMAIN=.lvh.me
