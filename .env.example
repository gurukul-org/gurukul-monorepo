# Docker Compose overlay selection
#   Local dev:  docker-compose.yml:docker-compose.dev.yml  (spins up local postgres + adminer)
#   VPS prod:   docker-compose.yml:docker-compose.prod.yml (joins external postgresql-k42d_default network)
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# PostgreSQL — only used by docker-compose.dev.yml (the local postgres service).
# On VPS, these aren't read; the shared postgres in the postgresql-k42d project owns its own creds.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=gurukul_dev

# DATABASE_URL host depends on which compose overlay is active:
#   local: host=postgres    (the service in docker-compose.dev.yml)
#   VPS:   host=postgresql  (the service in the external postgresql-k42d compose project)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public"

# Registry image refs — only set on VPS when pulling pre-built images.
# Defaults in docker-compose.yml point to ghcr.io/gurukul-org/gurukul-monorepo/{api,web}:latest.
# API_IMAGE=ghcr.io/gurukul-org/gurukul-monorepo/api:latest
# WEB_IMAGE=ghcr.io/gurukul-org/gurukul-monorepo/web:latest

# Access token and refresh token secrets.
# Generate with: openssl rand -hex 64
# Required at startup; the app will fail to boot if missing.
AT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
RT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET

# Multi-tenancy domain config
# APP_DOMAIN is the apex used to derive tenant subdomains from the Host header.
#   dev:     localhost
#   staging: staging.gurukul.io
#   prod:    gurukul.io
APP_DOMAIN=lvh.me

# COOKIE_DOMAIN controls the refreshToken cookie scope.
# Leave empty for host-only cookies (recommended for local dev).
# In prod, set to ".gurukul.io" to share the session across tenant subdomains.

# Email / password reset
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
FRONTEND_RESET_PASSWORD_URL=

COOKIE_DOMAIN=.lvh.me
