{
  "name": "@repo/permissions",
  "version": "1.0.0",
  "description": "Single source of truth for permission definitions, shared across api and web",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "lint": "prettier --check src",
    "format": "prettier --write src",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "typescript": "5.9.2"
  }
}
